{
  "compilerOptions": {
    "experimentalDecorators": true,
    "module": "commonjs",
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "types": ["node"],
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "typing",
    "node_modules/zotero-types"
  ],
  "exclude": [
    "builds",
    "addon"
  ]
}
